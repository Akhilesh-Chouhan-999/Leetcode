services:
  # ── Frontend ──────────────────────────────────────────────────────────────
  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    ports:
      - "3000:3000"
    environment:
      - REACT_APP_API_URL=http://api-gateway:8080
    depends_on:
      - api-gateway
    networks:
      - {{ project_name }}-net

  # ── API Gateway ───────────────────────────────────────────────────────────
  api-gateway:
    build:
      context: ./api-gateway
      dockerfile: Dockerfile
    ports:
      - "8080:8080"
    environment:
      - PORT=8080
    depends_on:
{% for svc in services %}
      - {{ svc.name }}
{% endfor %}
    networks:
      - {{ project_name }}-net

{% for svc in services %}
  # ── {{ svc.name | title }} Service ───────────────────────────────────────
  {{ svc.name }}:
    build:
      context: ./services/{{ svc.name }}
      dockerfile: Dockerfile
    environment:
      - PORT={{ svc.port }}
      - DATABASE_URL=postgresql://postgres:postgres@db-{{ svc.name }}:5432/{{ svc.name }}
    depends_on:
      - db-{{ svc.name }}
    networks:
      - {{ project_name }}-net

  db-{{ svc.name }}:
    image: postgres:15-alpine
    environment:
      POSTGRES_DB: {{ svc.name }}
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
    volumes:
      - db-{{ svc.name }}-data:/var/lib/postgresql/data
    networks:
      - {{ project_name }}-net

{% endfor %}

volumes:
{% for svc in services %}
  db-{{ svc.name }}-data:
{% endfor %}

networks:
  {{ project_name }}-net:
    driver: bridge
